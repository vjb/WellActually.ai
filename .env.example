# ═══════════════════════════════════════════════════════════════
# WellActually.ai — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to `.env` and fill in your real keys.
# The `.env` file is excluded from git via .gitignore.

# ── Claude Authentication ──
# NOTE: ANTHROPIC_API_KEY is NOT used by WellActually.ai.
# All LLM routing goes through AIML API (Partner Track) and Featherless AI.
# The lines below are retained only for reference if using Codeband locally.
# ANTHROPIC_API_KEY=sk-ant-...

# ── AIML API (Hackathon Sponsor — Partner Track) ────────────────
# Routes the Lead Coder Agent and Cart SME Reviewer Agent
# via the AIML API gateway using gpt-4o-mini.
OPENAI_API_KEY=your-aiml-api-key-here
OPENAI_BASE_URL=https://api.aimlapi.com/v1
AIML_API_KEY=your-aiml-api-key-here

# ── Featherless AI (Hackathon Sponsor) ──────────────────────────
# Routes the Auth & Fraud SME Reviewer Agent to
# unsloth/Meta-Llama-3.1-70B-Instruct on Featherless AI's
# serverless inference endpoint.
FEATHERLESS_API_KEY=rc_...

# ── Band.ai Platform ────────────────────────────────────────────
# Core agent orchestration: identity, chat rooms, participants,
# messages, mentions, context rehydration, events, and memories.
BAND_API_KEY=band_u_...

# ── GitHub Token ────────────────────────────────────────────────
# For issue and PR operations (optional for demo mode).
GH_TOKEN=ghp_...

# ── Memory Backend Override ─────────────────────────────────────
# Band.ai Memory API requires Enterprise plan. On Free/Pro tiers,
# the system automatically falls back to a local JSON memory store
# at mock_infrastructure/local_memories.json.
# Options: auto (default) | band | local
BAND_MEMORY_MODE=local

# ── Agent Reuse Keys (optional, for 10-agent limit bypass) ──────
# When more than 9 agents exist on the Band.ai platform, the
# system reuses pre-registered agent credentials instead of
# creating new ones. Set these from your Band dashboard.
# BAND_REUSE_CONDUCTOR_NAME=conductor-7c6144ef
# BAND_REUSE_CONDUCTOR_ID=...
# BAND_REUSE_CONDUCTOR_KEY=band_a_...
# BAND_REUSE_CODER_NAME=coder-7c6144ef
# BAND_REUSE_CODER_ID=...
# BAND_REUSE_CODER_KEY=band_a_...
# BAND_REUSE_REVIEWER_AUTH_NAME=reviewer-auth
# BAND_REUSE_REVIEWER_AUTH_ID=...
# BAND_REUSE_REVIEWER_AUTH_KEY=band_a_...
# BAND_REUSE_REVIEWER_CART_NAME=reviewer-cart
# BAND_REUSE_REVIEWER_CART_ID=...
# BAND_REUSE_REVIEWER_CART_KEY=band_a_...
